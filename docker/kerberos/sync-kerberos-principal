#!/bin/bash
# Real sync hook from LLDAP password change (single-container version)
# Args: $1 username, $2 obfuscated_pass (base64 of XOR with ENCODE_KEY)

USERNAME="$1"
OBFUSCATED_PASS="$2"

REALM_NAME="${REALM_NAME:-TESTLAB.COM}"
LOG_FILE="${LOG_FILE:-/var/log/krb5/sync.log}"
ENCODE_KEY="${LLDAP_ENCODE_KEY:-my-super-secret-shared-key-123!}"

# Ensure log dir exists
mkdir -p /var/log/krb5

if [ -z "$ENCODE_KEY" ]; then
    echo "ERROR: ENCODE_KEY missing—cannot deobfuscate" | tee -a $LOG_FILE
    exit 1
fi

if [ -z "$OBFUSCATED_PASS" ]; then
    echo "ERROR: No obfuscated password" | tee -a $LOG_FILE
    exit 1
fi

if [ -z "$USERNAME" ]; then
    echo "ERROR: No username provided" | tee -a $LOG_FILE
    exit 1
fi

# Deobfuscate with Python
PLAIN_PASS=$(python3 - <<EOF
import sys
import base64

obfuscated = "$OBFUSCATED_PASS"
key = "$ENCODE_KEY".encode('utf-8')
xored = base64.b64decode(obfuscated)

plain = bytes(x ^ key[i % len(key)] for i, x in enumerate(xored))
sys.stdout.buffer.write(plain)
EOF
)

echo "Syncing Kerberos principal $USERNAME@$REALM_NAME" | tee -a $LOG_FILE

# Try change password first (update if exists)
CPW_OUTPUT=$(kadmin.local -q "cpw -pw \"$PLAIN_PASS\" $USERNAME@$REALM_NAME" 2>&1)
CPW_STATUS=$?
echo "cpw output: $CPW_OUTPUT" | tee -a $LOG_FILE
if [ $CPW_STATUS -eq 0 ] && [[ $CPW_OUTPUT != *"Principal does not exist"* ]]; then
    echo "Success: Principal $USERNAME@$REALM_NAME updated via cpw" | tee -a $LOG_FILE
else
    # Fallback to add principal
    ADD_OUTPUT=$(kadmin.local -q "addprinc -pw \"$PLAIN_PASS\" $USERNAME@$REALM_NAME" 2>&1)
    ADD_STATUS=$?
    echo "addprinc output: $ADD_OUTPUT" | tee -a $LOG_FILE
    if [ $ADD_STATUS -eq 0 ]; then
        echo "Success: Principal $USERNAME@$REALM_NAME created via addprinc" | tee -a $LOG_FILE
    else
        echo "Failed to create/update principal $USERNAME@$REALM_NAME" | tee -a $LOG_FILE
        echo "Full error: $ADD_OUTPUT" | tee -a $LOG_FILE
        exit 1
    fi
fi
