#!/bin/bash
# Script trace mode (for debug)
if [ "${DEBUG_MODE:-false}" == "true" ]; then
    set -o xtrace
fi

# Predefine variables at top (with defaults/placeholders; optional noted)
FORCE_UPDATE="${FORCE_UPDATE:-false}"  # Bool to force update conf file on env change (optional, default false)
DEBUG_MODE="${DEBUG_MODE:-false}"  # Bool for trace mode (optional, default false)
LDAP_BACKEND="${LDAP_BACKEND:-false}"  # Bool for full LDAP mode (optional, default false - hybrid/local)
LDAP_HOST="${LDAP_HOST:-localhost}"  # LDAP host (optional, default localhost for internal)
LDAP_SCHEME="${LDAP_SCHEME:-ldap}"  # LDAP scheme (optional, default ldap)
LDAP_PORT="${LDAP_PORT:-3890}"  # LDAP port (optional, default 3890)
LLDAP_UI_PORT="${LLDAP_UI_PORT:-17170}"  # UI port (optional, default 17170)
REALM_NAME="${REALM_NAME:-TESTLAB.COM}"  # Kerberos realm (optional, default TESTLAB.COM)
BASE_DN="${BASE_DN:-dc=testlab,dc=com}"  # Base DN (optional, default testlab)
KDC_DN="${KDC_DN:-uid=krbkdc,ou=people,${BASE_DN}}"  # KDC DN (optional, default based on base DN)
ADMIN_DN="${ADMIN_DN:-uid=krbadm,ou=people,${BASE_DN}}"  # Admin DN (optional, default based on base DN)
CONTAINER_DN="${CONTAINER_DN:-cn=kerberos,ou=groups,${BASE_DN}}"  # Container DN (optional, default based on base DN)
DM_DN="${DM_DN:-uid=admin,ou=people,${BASE_DN}}"  # Dir manager DN (optional, default based on base DN)
MASTER_PASS="${MASTER_PASS:-your-strong-master-pass!}"  # Master DB pass (required; override with secure value)
ADMIN_PASS="${ADMIN_PASS:-your-strong-admin-pass!}"  # Admin principal pass (required)
KDC_PASS="${KDC_PASS:-your-strong-kdc-pass!}"  # KDC principal pass (required if LDAP_BACKEND=true)
DM_PASS="${DM_PASS:-adminpassword123!}"  # Dir manager pw (optional, for LDAP setup if needed)
LLDAP_ENCODE_KEY="${LLDAP_ENCODE_KEY:-my-super-secret-shared-key-123!}"  # Shared obfuscation key (required for sync)
ENCODE_KEY="${LLDAP_ENCODE_KEY}"  # Alias for backward compat (optional)

# If requested, perform a healthcheck and exit
if [[ ${1,,} == "healthcheck" ]]; then
    ps -p $(cat /var/run/krb5kdc.pid) | grep "krb5kdc" > /dev/null
    krb5kdc_status=$?
    ps -p $(cat /var/run/kadmind.pid) | grep "kadmind" > /dev/null
    kadmin_status=$?
    if [ $krb5kdc_status -ne 0 ] || [ $kadmin_status -ne 0 ]; then
        echo "Error: krb5kdc and/or kadmind service are no longer running. Healthcheck failed."
        exit 1
    fi
    exit 0
fi

echo "Starting Kerberos KDC/KADMIN container"

# Check for custom CA certs (Alpine path)
if [ -d "/etc/ssl/certs" ] && [ "$(ls -A /etc/ssl/certs)" ]; then
    echo "SSL certificate trust found. Running update-ca-certificates"
    update-ca-certificates
fi

# Load Kerberos config (replicate LLDAP model: copy/substitute template if missing or FORCE_UPDATE=true)
KERBEROS_CONFIG="/data/kerberos_config.toml"
FORCE_UPDATE="${FORCE_UPDATE:-false}"
if [ "$FORCE_UPDATE" == "true" ] || [ ! -f "$KERBEROS_CONFIG" ]; then
    echo "Generating kerberos_config.toml from template/env..."
    envsubst < /app/kerberos_config.template.toml > "$KERBEROS_CONFIG"
else
    echo "kerberos_config.toml exists and FORCE_UPDATE=false—loading existing."
fi

# Parse TOML to envs (simple grep/cut; assume [kerberos] section)
while IFS='=' read -r key value; do
    key=$(echo "$key" | tr -d ' ' | tr -d '[' | tr -d ']')
    value=$(echo "$value" | tr -d '"' | tr -d "'")
    export "$key"="$value"
done < <(grep -A 20 "\[kerberos\]" "$KERBEROS_CONFIG" | grep -v "\[kerberos\]" | grep "=")

# Now vars loaded (REALM_NAME, BASE_DN, etc.)

# Create dirs (for no file/pid/log)
mkdir -p /var/lib/krb5kdc /var/run /var/log/krb5

# Helper functions (warn instead of exit for flexibility)
ldap_create_person() {
    local ldap_url=$1
    local dn=$2
    local sn=$3

    echo "  - Adding user $sn at $dn"
    ldapadd -H $ldap_url -x -D "${DM_DN}" -w "${DM_PASS}" <<EOL
dn: $dn
objectClass: person
objectClass: top
objectClass: inetOrgPerson
objectClass: posixAccount
sn: $sn
cn: $sn
uid: $sn
mail: ${sn}@service.${REALM_NAME,,}
EOL
    status=$?
    if [ $status -ne 0 ] && [ $status -ne 68 ]; then
        echo "WARNING: Failed adding $dn (status $status)—continuing with local fallback."
    fi
}

# Setup LDAP if enabled (flexible, warn on fail)
if [ "$LDAP_BACKEND" == "true" ]; then
    echo "Setting up full LDAP backend..."
    # Install ldap tools if missing (Alpine flexibility)
    if ! command -v ldapadd > /dev/null; then
        echo "Installing openldap-clients..."
        apk add --no-cache openldap-clients
    fi

    # Create container/entries if needed (warn, don't exit)
    ldap_create_person "$ldap_url" "${CONTAINER_DN}" "kerberos"
    ldap_create_person "$ldap_url" "${KDC_DN}" "krbkdc"
    ldap_create_person "$ldap_url" "${ADMIN_DN}" "krbadm"

    # Add principals (flexible, use defaults)
    echo "Adding kdc/admin principals to LDAP..."
    kadmin.local -q "addprinc -pw ${KDC_PASS} krbkdc/admin@${REALM_NAME}"
    kadmin.local -q "addprinc -pw ${ADMIN_PASS} krbadm/admin@${REALM_NAME}"

    # LDAP creds file
    echo "${KDC_DN}:${KDC_PASS}" > /var/lib/krb5kdc/ldap.creds
    echo "${ADMIN_DN}:${ADMIN_PASS}" >> /var/lib/krb5kdc/ldap.creds
else
    echo "Hybrid/local mode: Using local Kerberos DB (recommended for LLDAP)."
fi

# Local init always (safe fallback)
echo "Configuring local Kerberos database."
kdb5_util create -s -r "${REALM_NAME}" -P "${MASTER_PASS}"
status=$?
if [ $status -ne 0 ]; then
    echo "WARNING: Local Kerberos init failed (status $status)—services may not start."
else
    echo "Adding admin principal..."
    kadmin.local -q "addprinc -pw ${ADMIN_PASS} admin/admin@${REALM_NAME}"
    echo "Creating admin keytab..."
    kadmin.local -q "ktadd -norandkey -k /var/lib/krb5kdc/kadm5.keytab admin/admin@${REALM_NAME}"
    echo "*/admin@${REALM_NAME} *" > /var/lib/krb5kdc/kadm5.acl
fi

# Start Kerberos services
echo "Starting kadmind..."
kadmind -P /var/run/kadmind.pid
echo "Starting krb5kdc..."
krb5kdc -P /var/run/krb5kdc.pid

# Show kdc logging as output. Tail will exit when receiving SIGTERM.
tail -F /var/log/krb5/krb5kdc.log &
tail_pid=$!
trap 'kill $tail_pid' TERM INT
wait $tail_pid

# Shutdown
echo "Shutting down krb5kdc..."
kill $(cat /var/run/krb5kdc.pid)
echo "Shutting down kadmind..."
kill $(cat /var/run/kadmind.pid)

# Wait for clean shutdown
while true; do
    ps -p $(cat /var/run/krb5kdc.pid) | grep "krb5kdc" > /dev/null
    krb5kdc_status=$?
    ps -p $(cat /var/run/kadmind.pid) | grep "kadmind" > /dev/null
    kadmin_status=$?
    if [ $krb5kdc_status -ne 0 ] && [ $kadmin_status -ne 0 ]; then
        exit 0
    fi
    sleep 1
done
