#!/bin/bash

# Script trace mode (for debug)
if [ "${DEBUG_MODE:-false}" == "true" ]; then
    set -o xtrace
fi

# If requested, perform a healthcheck and exit
if [[ ${1,,} == "healthcheck" ]]; then
    ps -p $(cat /var/run/krb5kdc.pid) | grep "krb5kdc" > /dev/null
    krb5kdc_status=$?
    ps -p $(cat /var/run/kadmind.pid) | grep "kadmind" > /dev/null
    kadmin_status=$?
    if [ $krb5kdc_status -ne 0 ] || [ $kadmin_status -ne 0 ]; then
        echo "Error: krb5kdc and/or kadmind service are no longer running. Healthcheck failed."
        exit 1
    fi
    exit 0
fi

echo "Starting Kerberos KDC/KADMIN container"

# Check for custom CA certs (Alpine path)
if [ -d "/etc/ssl/certs" ] && [ "$(ls -A /etc/ssl/certs)" ]; then
    echo "SSL certificate trust found. Running update-ca-certificates"
    update-ca-certificates
fi

# Hybrid mode: Default local backend (safe for LLDAP); optional full LDAP if LDAP_BACKEND=true
LDAP_BACKEND=${LDAP_BACKEND:-false}
if [ "$LDAP_BACKEND" == "true" ] && [ -z "${LDAP_HOST}" ]; then
    echo "WARNING: LDAP_BACKEND=true but LDAP_HOST not set. Falling back to local."
    LDAP_BACKEND=false
fi

# Flexible LDAP scheme and port (default ldap:3890 for LLDAP; override for prod)
if [ "$LDAP_BACKEND" == "true" ]; then
    LDAP_SCHEME=${LDAP_SCHEME:-ldap}
    LDAP_PORT=${LDAP_PORT:-3890}
    ldap_url=${LDAP_SCHEME}://${LDAP_HOST}:${LDAP_PORT}
    echo "Full LDAP backend enabled (experimental with LLDAP—limitations on Kerberos subtree)."
fi

# LLDAP UI port for lldap-cli (default 17170; assumes UI on localhost in container)
LLDAP_UI_PORT=${LLDAP_UI_PORT:-17170}

# usage: file_env VAR [DEFAULT]
# Loads var from ENV or file, with default; unsets _FILE after
file_env() {
    local var="$1"
    local fileVar="${var}_FILE"
    local defaultValue="${2:-}"

    local val="$defaultValue"

    if [ "${!var:-}" ]; then
        val="${!var}"
        echo "** Using ${var} from ENV"
    elif [ "${!fileVar:-}" ]; then
        if [ ! -f "${!fileVar}" ]; then
            echo "WARNING: Secret file \"${!fileVar}\" not found. Falling back to default for $var."
        else
            val="$(< "${!fileVar}")"
            echo "** Using ${var} from secret file"
        fi
    fi
    export "$var"="$val"
    unset "$fileVar"
}

# Load secrets/flexible envs (synced with LLDAP where possible, e.g., LLDAP_ENCODE_KEY)
file_env 'MASTER_PASS' 'your-strong-master-pass!'
file_env 'ADMIN_PASS' 'your-strong-admin-pass!'
file_env 'KDC_PASS' 'your-strong-kdc-pass!'
file_env 'DM_PASS' 'adminpassword123!'  # Optional for LDAP setup
file_env 'LLDAP_ENCODE_KEY' 'my-super-secret-shared-key-123!'  # Synced with LLDAP hook
ENCODE_KEY="${LLDAP_ENCODE_KEY}"  # Alias for backward compat

REALM_NAME="${REALM_NAME:-TESTLAB.COM}"
BASE_DN="${BASE_DN:-dc=testlab,dc=com}"
KDC_DN="${KDC_DN:-uid=krbkdc,ou=people,${BASE_DN}}"
ADMIN_DN="${ADMIN_DN:-uid=krbadm,ou=people,${BASE_DN}}"
CONTAINER_DN="${CONTAINER_DN:-cn=kerberos,ou=groups,${BASE_DN}}"
DM_DN="${DM_DN:-uid=admin,ou=people,${BASE_DN}}"

# Helper functions (warn instead of exit for flexibility)
ldap_create_person() {
    local ldap_url=$1
    local dn=$2
    local sn=$3

    echo "  - Adding user $sn at $dn"
    ldapadd -H $ldap_url -x -D "${DM_DN}" -w "${DM_PASS}" <<EOL
dn: $dn
objectClass: person
objectClass: top
objectClass: inetOrgPerson
objectClass: posixAccount
sn: $sn
cn: $sn
uid: $sn
mail: ${sn}@service.${REALM_NAME,,}
EOL
    status=$?
    if [ $status -ne 0 ] && [ $status -ne 68 ]; then
        echo "WARNING: Failed adding $dn (status $status)—continuing with local fallback."
    fi
}

# Setup LDAP if enabled (flexible, warn on fail)
if [ "$LDAP_BACKEND" == "true" ]; then
    echo "Setting up full LDAP backend..."
    # Install ldap tools if missing (Alpine flexibility)
    if ! command -v ldapadd > /dev/null; then
        echo "Installing openldap-clients..."
        apk add --no-cache openldap-clients
    fi

    # Create container/entries if needed (warn, don't exit)
    ldap_create_person "$ldap_url" "${CONTAINER_DN}" "kerberos"
    ldap_create_person "$ldap_url" "${KDC_DN}" "krbkdc"
    ldap_create_person "$ldap_url" "${ADMIN_DN}" "krbadm"

    # Add principals (flexible, use defaults)
    echo "Adding kdc/admin principals to LDAP..."
    kadmin.local -q "addprinc -pw ${KDC_PASS} krbkdc/admin@${REALM_NAME}"
    kadmin.local -q "addprinc -pw ${ADMIN_PASS} krbadm/admin@${REALM_NAME}"

    # LDAP creds file
    echo "${KDC_DN}:${KDC_PASS}" > /var/krb5kdc/ldap.creds
    echo "${ADMIN_DN}:${ADMIN_PASS}" >> /var/krb5kdc/ldap.creds
else
    echo "Hybrid/local mode: Using local Kerberos DB (recommended for LLDAP)."
fi

# Local init always (safe fallback)
echo "Configuring local Kerberos database."
kdb5_util create -s -r "${REALM_NAME}" -P "${MASTER_PASS}"
status=$?
if [ $status -ne 0 ]; then
    echo "WARNING: Local Kerberos init failed (status $status)—services may not start."
else
    echo "Adding admin principal..."
    kadmin.local -q "addprinc -pw ${ADMIN_PASS} admin/admin@${REALM_NAME}"
    echo "Creating admin keytab..."
    kadmin.local -q "ktadd -norandkey -k /var/krb5kdc/kadm5.keytab admin/admin@${REALM_NAME}"
    echo "*/admin@${REALM_NAME} *" > /var/krb5kdc/kadm5.acl
fi

# Generate kdc.conf (local always, LDAP optional)
echo " - Generating /var/krb5kdc/kdc.conf"
cat > /var/krb5kdc/kdc.conf <<EOF
[kdcdefaults]
    kdc_ports = 750,88
[realms]
    ${REALM_NAME} = {
EOF
if [ "$LDAP_BACKEND" == "true" ]; then
    cat >> /var/krb5kdc/kdc.conf <<EOF
        database_module = contact_ldap
EOF
fi
cat >> /var/krb5kdc/kdc.conf <<EOF
    }
[dbdefaults]
[dbmodules]
EOF
if [ "$LDAP_BACKEND" == "true" ]; then
    cat >> /var/krb5kdc/kdc.conf <<EOF
    contact_ldap = {
            db_library = kldap
            ldap_kdc_dn = "${KDC_DN}"
            ldap_kadmind_dn = "${ADMIN_DN}"
            ldap_kerberos_container_dn = "${CONTAINER_DN}"
            ldap_service_password_file = /var/krb5kdc/ldap.creds
            ldap_servers = $ldap_url
    }
EOF
fi
cat >> /var/krb5kdc/kdc.conf <<EOF
[logging]
    kdc = FILE:/var/log/krb5/krb5kdc.log
    admin_server = FILE:/var/log/krb5/kadmind.log
EOF

# Start Kerberos services
echo "Starting kadmind..."
kadmind -P /var/run/kadmind.pid
echo "Starting krb5kdc..."
krb5kdc -P /var/run/krb5kdc.pid

# Show kdc logging as output. Tail will exit when receiving SIGTERM.
tail -f /var/log/krb5/krb5kdc.log &
tail_pid=$!
trap 'kill $tail_pid' TERM INT
wait $tail_pid

# Shutdown
echo "Shutting down krb5kdc..."
kill $(cat /var/run/krb5kdc.pid)
echo "Shutting down kadmind..."
kill $(cat /var/run/kadmind.pid)

# Wait for clean shutdown
while true; do
    ps -p $(cat /var/run/krb5kdc.pid) | grep "krb5kdc" > /dev/null
    krb5kdc_status=$?
    ps -p $(cat /var/run/kadmind.pid) | grep "kadmind" > /dev/null
    kadmin_status=$?
    if [ $krb5kdc_status -ne 0 ] && [ $kadmin_status -ne 0 ]; then
        exit 0
    fi
    sleep 1
done
