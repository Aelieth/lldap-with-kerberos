#!/bin/bash

# Script-specific vars at top (not in TOML)
DEBUG_MODE="${DEBUG_MODE:-false}" # Bool for trace mode (optional, default false)
LLDAP_UI_PORT="${LLDAP_UI_PORT:-17170}" # UI port (optional, default 17170)

# Script trace mode
if [ "$DEBUG_MODE" == "true" ]; then
    set -o xtrace
fi

# If requested, perform a healthcheck and exit
if [[ ${1,,} == "healthcheck" ]]; then
    ps -p $(cat /var/run/krb5kdc.pid) | grep "krb5kdc" > /dev/null
    krb5kdc_status=$?
    ps -p $(cat /var/run/kadmind.pid) | grep "kadmind" > /dev/null
    kadmin_status=$?
    if [ $krb5kdc_status -ne 0 ] || [ $kadmin_status -ne 0 ]; then
        echo "Error: krb5kdc and/or kadmind service are no longer running. Healthcheck failed."
        exit 1
    fi
    exit 0
fi

echo "Starting Kerberos KDC/KADMIN container"

# Check for custom CA certs (Alpine path)
if [ -d "/etc/ssl/certs" ] && [ "$(ls -A /etc/ssl/certs)" ]; then
    echo "SSL certificate trust found. Running update-ca-certificates"
    update-ca-certificates
fi

# Create necessary directories (from original, adapted for Alpine - fix log/PID not found)
mkdir -p /var/log/krb5 /var/lib/krb5kdc /var/run /tmp

# Kerberos Config Setup (mimic LLDAP: one-time copy/substitute from template to /data/kerberos_config.toml)
KERBEROS_CONFIG_FILE="/data/kerberos_config.toml"
KERBEROS_TEMPLATE="/app/kerberos_config.template.toml"  # Path to template in container

if [ ! -f "$KERBEROS_CONFIG_FILE" ]; then
    echo "Kerberos config not found. Copying and substituting template to $KERBEROS_CONFIG_FILE"
    if envsubst < "$KERBEROS_TEMPLATE" > "$KERBEROS_CONFIG_FILE"; then
        echo "Kerberos config generated successfully."
    else
        echo "ERROR: Failed to generate kerberos_config.toml from template—using defaults, but may fail."
    fi
else
    echo "Kerberos config already exists—skipping copy."
fi

# Load vars from kerberos_config.toml (using Python for safe parse/export - handles odd chars)
echo "Loading vars from $KERBEROS_CONFIG_FILE..."
python3 - <<EOF
import toml
import os

try:
    config = toml.load("$KERBEROS_CONFIG_FILE")['kerberos']
    for key, value in config.items():
        os.environ[key.upper()] = str(value)
    print("Vars loaded from TOML.")
except Exception as e:
    print(f"WARNING: TOML load failed ({e})—falling back to env/defaults.")
EOF

# Apply priority: KERB_ env (user override) > TOML > LLDAP_ shared (where applicable) > default
# Hardcode static vars (no options)
LDAP_SCHEME="ldap"
LDAP_PORT="3890"
KDC_DN="uid=krbkdc,ou=people,\${BASE_DN}"  # Not used, but defined for completeness
ADMIN_DN="uid=krbadm,ou=people,\${BASE_DN}"  # Not used
CONTAINER_DN="cn=kerberos,ou=groups,\${BASE_DN}"  # Not used
DM_DN="uid=admin,ou=people,\${BASE_DN}"  # Used implicitly in schema

BASE_DN="${KERB_BASE_DN:-${BASE_DN:-${LLDAP_LDAP_BASE_DN:-dc=testlab,dc=com}}}"
MASTER_PASS="${KERB_MASTER_PASS:-${MASTER_PASS:-your-strong-master-pass!}}"
ADMIN_PASS="${KERB_ADMIN_PASS:-${ADMIN_PASS:-your-strong-admin-pass!}}"
DM_PASS="${KERB_DM_PASS:-${DM_PASS:-${LLDAP_LDAP_USER_PASS:-adminpassword123!}}}"

# Derive REALM_NAME from BASE_DN if not set (uppercase domain)
REALM_NAME="${KERB_REALM_NAME:-${REALM_NAME}}"
if [ -z "$REALM_NAME" ]; then
    REALM_NAME=$(echo "${BASE_DN}" | sed 's/dc=//g; s/,/\./g' | tr '[:lower:]' '[:upper:]')
fi
REALM_NAME="${REALM_NAME:-TESTLAB.COM}"
export REALM_NAME
ENCODE_KEY="${LLDAP_ENCODE_KEY}"

# Derive DOMAIN from BASE_DN (lowercase for domain_realm)
DOMAIN=$(echo "${BASE_DN}" | sed 's/dc=//g; s/,/\./g')
export DOMAIN
echo "Calculated DOMAIN=${DOMAIN}"

# Extended configurable vars (for krb5.conf and kdc.conf)
TICKET_LIFETIME="${KERB_TICKET_LIFETIME:-24h}"
RENEW_LIFETIME="${KERB_RENEW_LIFETIME:-7d}"
FORWARDABLE="${KERB_FORWARDABLE:-true}"
RDNS="${KERB_RDNS:-false}"

export KDC_PORT ADMIN_PORT KDC_UDP_PORTS TICKET_LIFETIME RENEW_LIFETIME FORWARDABLE RDNS

# Echo effective vars for debug (trimmed list)
echo "Effective REALM_NAME=${REALM_NAME}"
echo "Effective BASE_DN=${BASE_DN}"
echo "Effective DM_PASS length=${#DM_PASS}"
echo "Effective ENCODE_KEY=${ENCODE_KEY}"

# Generate conf from templates (every time)
echo "Generating /etc/krb5.conf..."
if envsubst < /app/krb5.template.conf > /etc/krb5.conf; then
    echo "/etc/krb5.conf generated."
    cat /etc/krb5.conf
else
    echo "ERROR: /etc/krb5.conf gen failed."
    exit 1
fi

# Generate server kdc.conf (forces single aes256 master/supported for krbtgt matching user principals)
echo "Generating server /var/lib/krb5kdc/kdc.conf from simplified template..."
mkdir -p /var/lib/krb5kdc
if envsubst < /app/kdc.template.conf > /var/lib/krb5kdc/kdc.conf; then
    echo "/var/lib/krb5kdc/kdc.conf generated successfully."
    cat /var/lib/krb5kdc/kdc.conf  # Debug in logs
else
    echo "ERROR: Failed to generate /var/lib/krb5kdc/kdc.conf"
    exit 1
fi

# One-time schema
SCHEMA_FLAG="/var/lib/krb5kdc/schema_extended.flag"
if [ ! -f "$SCHEMA_FLAG" ]; then
    echo "Performing one-time schema extension..."
    export LLDAP_HTTPURL="http://localhost:${LLDAP_UI_PORT}"
    export LLDAP_USERNAME="admin"
    export LLDAP_PASSWORD="${DM_PASS}"
    echo "Using LLDAP_HTTPURL=${LLDAP_HTTPURL} LLDAP_USERNAME=admin LLDAP_PASSWORD length=${#LLDAP_PASSWORD}"

    lldap-cli schema attribute user add uidNumber INTEGER -e
    lldap-cli schema attribute user add gidNumber INTEGER -e
    lldap-cli schema objectclass user add inetOrgPerson
    lldap-cli schema objectclass user add posixAccount

    if [ $? -eq 0 ]; then
        echo "Schema extension success."
        touch "$SCHEMA_FLAG"
    else
        echo "WARNING: Schema extension failed."
    fi
else
    echo "Schema already extended—skipping."
fi

# DB init if not exist
if [ ! -f /var/lib/krb5kdc/principal ]; then
    echo "Kerberos database not found. Starting configuration."
    echo "Hybrid/local mode: Using local Kerberos DB for principals (recommended for LLDAP)."

    echo "Configuring local Kerberos database."
    /usr/sbin/kdb5_util create -s -r "${REALM_NAME}" -P "${MASTER_PASS}"
    status=$?
    if [ $status -ne 0 ]; then
        echo "ERROR: Local Kerberos initialization failed (status $status)."
    else
        echo "Adding admin principal..."
        kadmin.local -q "addprinc -pw ${ADMIN_PASS} -e aes256-cts-hmac-sha1-96:normal admin/admin@${REALM_NAME}"
        echo "Creating admin keytab..."
        kadmin.local -q "ktadd -norandkey -k /var/lib/krb5kdc/kadm5.keytab admin/admin@${REALM_NAME}"
        echo "*/admin@${REALM_NAME} *" > /var/lib/krb5kdc/kadm5.acl
    fi
fi

# Start services
echo "Starting kadmind..."
/usr/sbin/kadmind -P /var/run/kadmind.pid
echo "Starting krb5kdc..."
/usr/sbin/krb5kdc -P /var/run/krb5kdc.pid

# Tail logs
tail -f /var/log/krb5/krb5kdc.log &
tail_pid=$!
trap 'kill $tail_pid' TERM INT
wait $tail_pid

# Shutdown
echo "Shutting down krb5kdc..."
kill $(cat /var/run/krb5kdc.pid)
echo "Shutting down kadmind..."
kill $(cat /var/run/kadmind.pid)

# Wait for clean shutdown
while true; do
    ps -p $(cat /var/run/krb5kdc.pid) | grep "/usr/sbin/krb5kdc" > /dev/null
    krb5kdc_status=$?
    ps -p $(cat /var/run/kadmind.pid) | grep "/usr/sbin/kadmind" > /dev/null
    kadmin_status=$?
    if [ $krb5kdc_status -ne 0 ] && [ $kadmin_status -ne 0 ]; then
        exit 0
    fi
    sleep 1
done
